generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Artisan {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  logo     String?
  history  String?
  featured Boolean   @default(false)
  products Product[]
  chatUsers ChatUser[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  image       String?
  category    Category
  artisanId   String
  artisan     Artisan  @relation(fields: [artisanId], references: [id])
  createdAt   DateTime @default(now())
}

enum Category {
  VAISSELLE
  VERRERIE
  COUVERTS
  LINGE_DE_TABLE
  DECORATION
  AUTRE
}

model Machine {
  id          String   @id @default(cuid())
  name        String
  description String?
  image       String?
  specs       Json?
  highlights  String[]
  createdAt   DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  author    String
  role      String?
  quote     String
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SiteContent {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model ContactRequest {
  id          String   @id @default(cuid())
  lastName    String
  firstName   String
  company     String?
  email       String
  phone       String?
  need        String
  message     String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model RendezVous {
  id            String   @id @default(cuid())
  lastName      String
  firstName     String
  company       String?
  email         String
  phone         String?
  projectType   String
  preferredDate String?
  preferredTime String?
  message       String?
  status        RdvStatus @default(PENDING)
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())
}

enum RdvStatus {
  PENDING
  CONFIRMED
  CANCELLED
}



model ChatUser {
  id        String       @id @default(cuid())
  email     String       @unique
  password  String
  firstName String
  lastName  String
  role      ChatUserRole @default(CLIENT)
  artisanId String?      // если ARTISAN — ссылка на artisan
  artisan   Artisan?     @relation(fields: [artisanId], references: [id])
  createdAt DateTime     @default(now())

  // Relations
  roomsAsClient   ChatRoom[] @relation("ClientRooms")
  roomsAsArtisan  ChatRoom[] @relation("ArtisanRooms")
  messages        Message[]
}

enum ChatUserRole {
  CLIENT
  ARTISAN
  ADMIN
}

// ── Комнаты чата ───────────────────────────────────────────────────────────

model ChatRoom {
  id         String    @id @default(cuid())
  clientId   String
  artisanId  String
  client     ChatUser  @relation("ClientRooms",  fields: [clientId],  references: [id])
  artisan    ChatUser  @relation("ArtisanRooms", fields: [artisanId], references: [id])
  createdAt  DateTime  @default(now())
  lastMsgAt  DateTime  @default(now())
  messages   Message[]

  @@unique([clientId, artisanId]) // один диалог на пару
}

// ── Сообщения ──────────────────────────────────────────────────────────────

model Message {
  id         String      @id @default(cuid())
  roomId     String
  senderId   String
  room       ChatRoom    @relation(fields: [roomId],   references: [id])
  sender     ChatUser    @relation(fields: [senderId], references: [id])
  type       MessageType @default(TEXT)
  content    String      // текст или URL файла
  fileName   String?     // оригинальное имя файла
  fileSize   Int?        // в байтах
  read       Boolean     @default(false)
  createdAt  DateTime    @default(now())
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

